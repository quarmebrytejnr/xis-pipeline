# ─── Inflow Cloud Inventory ────────────────────────────────────────────────────
# Found in: Inflow Cloud → Settings → API Keys
INFLOW_API_KEY=your_inflow_api_key_here
INFLOW_COMPANY_ID=your_inflow_company_id_here

# ─── Xero OAuth2 ──────────────────────────────────────────────────────────────
# Found in: https://developer.xero.com/myapps → your app → OAuth 2.0 credentials
# Run the initial auth flow once (see README) to get the refresh token.
XERO_CLIENT_ID=your_xero_client_id_here
XERO_CLIENT_SECRET=your_xero_client_secret_here
XERO_REFRESH_TOKEN=your_initial_refresh_token_here
XERO_TENANT_ID=your_xero_tenant_id_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
# Use the service_role key (not the anon key) for write access.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ─── GitHub Actions (optional) ────────────────────────────────────────────────
# A personal access token with `secrets` write scope.
# Required only if you want the SDK to auto-rotate XERO_REFRESH_TOKEN in GitHub.
GH_PAT=ghp_your_personal_access_token_here
